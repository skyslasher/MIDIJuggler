[Unit]
Description=GamePi13 brightness keys (L/R shoulder buttons)
After=systemd-udev-settle.service
Wants=systemd-udev-settle.service

[Service]
Type=simple
WorkingDirectory=/var/lib/gamepi
Environment=GAMEPI_LGPIO_DIR=/var/lib/gamepi
Environment=GAMEPI_BRIGHTNESS_STEP=10
Environment=GAMEPI_BACKLIGHT_GPIO_CANDIDATES=24
Environment=GAMEPI_BRIGHTNESS_DEFAULT=200
Environment=GAMEPI_PWM_BACKLIGHT=1
EnvironmentFile=-/etc/midijuggler/brightness.env
ExecStart=/usr/bin/python3 /opt/midijuggler/app/scripts/gamepi-brightness-keys.py
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
