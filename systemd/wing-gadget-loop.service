[Unit]
Description=Route USB gadget capture to Wing USB channels 5-6
After=sound.target
Wants=sound.target

[Service]
Type=simple
Environment=MIDIJUGGLER_SCRIPTS_DIR=/opt/midijuggler/app/scripts
Environment=WING_PLAYBACK=wing_stereo3
ExecStart=/opt/midijuggler/app/scripts/wing-gadget-loop.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
